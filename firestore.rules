rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users: only the owner can read/write their own doc
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Couples: both partners can read/write
    match /couples/{coupleId} {
      allow read, write: if request.auth != null;
    }

    // Hugs: authenticated users can read/write
    match /hugs/{hugId} {
      allow read, write: if request.auth != null;
    }

    // Invites: anyone authenticated can read, creator can write
    match /invites/{token} {
      allow read, write: if request.auth != null;
    }

    // Hug requests: authenticated users
    match /hugRequests/{reqId} {
      allow read, write: if request.auth != null;
    }
  }
}
